# Copy to .env and fill in. Only OPENROUTER_API_KEY + GITHUB_TOKEN are required.
OPENROUTER_API_KEY=your_openrouter_key
GITHUB_TOKEN=your_github_token_repo_workflow_scopes

# Optional extras Hermes supports out of the box:
# SERPER_API_KEY=            # real Google search (serper.dev)
# ZAI_API_KEY=                # Z.AI / GLM as fallback provider
# GOOGLE_API_KEY=             # native Gemini
